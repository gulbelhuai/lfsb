<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.shebao.mapper.VillageOfficialPositionMapper">
    
    <resultMap type="com.ruoyi.shebao.domain.VillageOfficialPosition" id="VillageOfficialPositionResult">
        <result property="id"                          column="id"                          />
        <result property="villageOfficialId"           column="village_official_id"         />
        <result property="position"                    column="position"                    />
        <result property="startDate"                   column="start_date"                  />
        <result property="endDate"                     column="end_date"                    />
        <result property="serviceYears"                column="service_years"               />
        <result property="status"                      column="status"                      />
        <result property="delFlag"                     column="del_flag"                    />
        <result property="createBy"                    column="create_by"                   />
        <result property="createTime"                  column="create_time"                 />
        <result property="updateBy"                    column="update_by"                   />
        <result property="updateTime"                  column="update_time"                 />
        <result property="remark"                      column="remark"                      />
    </resultMap>

    <resultMap type="com.ruoyi.shebao.dto.VillageOfficialFormDto$VillageOfficialPositionDto" id="VillageOfficialPositionDtoResult">
        <result property="id"                          column="id"                          />
        <result property="villageOfficialId"           column="village_official_id"         />
        <result property="position"                    column="position"                    />
        <result property="startDate"                   column="start_date"                  />
        <result property="endDate"                     column="end_date"                    />
        <result property="serviceYears"                column="service_years"               />
        <result property="status"                      column="status"                      />
        <result property="remark"                      column="remark"                      />
    </resultMap>

    <sql id="selectVillageOfficialPositionVo">
        select vop.id, vop.village_official_id, vop.position, vop.start_date, 
               vop.end_date, vop.service_years, vop.status, vop.del_flag, vop.create_by, vop.create_time, 
               vop.update_by, vop.update_time, vop.remark 
        from shebao_village_official_position vop
    </sql>

    <select id="selectByVillageOfficialId" parameterType="Long" resultMap="VillageOfficialPositionDtoResult">
        select vop.id, vop.village_official_id, vop.position, vop.start_date, 
               vop.end_date, vop.service_years, vop.status, vop.remark
        from shebao_village_official_position vop
        where vop.village_official_id = #{villageOfficialId} and vop.del_flag = '0'
        order by vop.id desc
    </select>

    <delete id="deleteByVillageOfficialId" parameterType="Long">
        update shebao_village_official_position 
        set del_flag = '2'
        where village_official_id = #{villageOfficialId}
    </delete>

    <insert id="batchInsertPositions" parameterType="java.util.List">
        insert into shebao_village_official_position
        (village_official_id, position, start_date, end_date, service_years,
         status, create_by, create_time, remark)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.villageOfficialId}, #{item.position}, #{item.startDate}, #{item.endDate}, #{item.serviceYears},
             #{item.status}, #{item.createBy}, #{item.createTime}, #{item.remark})
        </foreach>
    </insert>

</mapper>
