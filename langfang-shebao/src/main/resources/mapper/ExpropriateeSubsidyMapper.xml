    <sql id="selectExpropriateeSubsidyVo">
        select es.id, es.subsidy_person_id, es.land_requisition_batch, es.village_street, es.base_date, 
               es.employee_pension_months, es.flexible_employment_months, es.difficulty_subsidy_years, 
               es.age_at_base_date, es.subsidy_years, es.subsidy_amount, 
               es.join_urban_rural_insurance, es.join_employee_pension, es.has_employee_pension,
               es.status, es.del_flag, es.create_by, es.create_time, 
               es.update_by, es.update_time, es.remark 
        from shebao_expropriatee_subsidy es
    </sql>

    <select id="selectExpropriateeSubsidyList" parameterType="com.ruoyi.shebao.dto.ExpropriateeSubsidyListReq" resultMap="ExpropriateeSubsidyListRespResult">
        select es.id, es.subsidy_person_id, es.land_requisition_batch, es.village_street, es.base_date, 
               es.age_at_base_date, es.subsidy_years, es.subsidy_amount, 
               es.join_urban_rural_insurance, es.join_employee_pension, 
               es.status, es.create_time, es.update_time, es.remark,
               sp.name, sp.id_card_no, sp.gender, sp.phone, sp.approval_status,
               svc.village_name
        from shebao_expropriatee_subsidy es
        left join shebao_subsidy_person sp on es.subsidy_person_id = sp.id
        left join shebao_village_committee svc on sp.village_committee_id = svc.id
        <where>
            es.del_flag = '0'
            <if test="req.name != null and req.name != ''">
                AND sp.name like concat('%', #{req.name}, '%')
            </if>
            <if test="req.idCardNo != null and req.idCardNo != ''">
                AND sp.id_card_no like concat('%', #{req.idCardNo}, '%')
            </if>
            <if test="req.userCode != null and req.userCode != ''">
                AND sp.user_code = #{req.userCode}
            </if>
            <if test="req.streetOfficeId != null">
                AND sp.street_office_id = #{req.streetOfficeId}
            </if>
            <if test="req.villageCommitteeId != null">
                AND sp.village_committee_id = #{req.villageCommitteeId}
            </if>
            <if test="req.approvalStatus != null and req.approvalStatus != ''">
                AND sp.approval_status = #{req.approvalStatus}
            </if>
            <if test="req.landRequisitionBatch != null and req.landRequisitionBatch != ''">
                AND es.land_requisition_batch like concat('%', #{req.landRequisitionBatch}, '%')
            </if>
            <if test="req.baseDateStart != null">
                AND es.base_date >= #{req.baseDateStart}
            </if>
            <if test="req.baseDateEnd != null">
                AND es.base_date &lt;= #{req.baseDateEnd}
            </if>
            <if test="req.villageCode != null and req.villageCode != ''">
                AND svc.village_code = #{req.villageCode}
            </if>
            <if test="req.joinUrbanRuralInsurance != null and req.joinUrbanRuralInsurance != ''">
                AND es.join_urban_rural_insurance = #{req.joinUrbanRuralInsurance}
            </if>
            <if test="req.joinEmployeePension != null and req.joinEmployeePension != ''">
                AND es.join_employee_pension = #{req.joinEmployeePension}
            </if>
            <if test="req.status != null and req.status != ''">
                AND es.status = #{req.status}
            </if>
        </where>
        order by es.create_time desc
    </select>

    <select id="selectExpropriateeSubsidyFormById" parameterType="Long" resultMap="ExpropriateeSubsidyFormResult">
        select es.id, es.subsidy_person_id, es.land_requisition_batch, es.village_street, es.base_date, 
               es.employee_pension_months, es.flexible_employment_months, es.difficulty_subsidy_years, 
               es.age_at_base_date, es.subsidy_years, es.subsidy_amount, 
               es.join_urban_rural_insurance, es.join_employee_pension, es.has_employee_pension,
               es.status as es_status, es.remark as es_remark,
               sp.name, sp.gender, sp.id_card_no, sp.birthday, sp.household_registration, 
               sp.home_address, sp.phone, sp.is_alive, sp.death_date, sp.is_village_coop_member, 
               sp.street_office_id, sp.village_committee_id, sp.user_code
        from shebao_expropriatee_subsidy es
        left join shebao_subsidy_person sp on es.subsidy_person_id = sp.id
        where es.id = #{id} and es.del_flag = '0'
    </select>

    <select id="selectBySubsidyPersonId" parameterType="Long" resultMap="ExpropriateeSubsidyResult">
        <include refid="selectExpropriateeSubsidyVo"/>
        where subsidy_person_id = #{subsidyPersonId} and del_flag = '0'
        order by create_time desc
    </select>

    <insert id="batchInsertExpropriateeSubsidy" parameterType="java.util.List">
        insert into shebao_expropriatee_subsidy
        (subsidy_person_id, land_requisition_batch, village_street, base_date, employee_pension_months, 
         flexible_employment_months, difficulty_subsidy_years, age_at_base_date, 
         subsidy_years, subsidy_amount, join_urban_rural_insurance, join_employee_pension, 
         has_employee_pension, status, create_by, create_time, remark)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.subsidyPersonId}, #{item.landRequisitionBatch}, #{item.villageStreet}, #{item.baseDate}, 
             #{item.employeePensionMonths}, #{item.flexibleEmploymentMonths}, #{item.difficultySubsidyYears}, 
             #{item.ageAtBaseDate}, #{item.subsidyYears}, #{item.subsidyAmount}, 
             #{item.joinUrbanRuralInsurance}, #{item.joinEmployeePension}, #{item.hasEmployeePension}, #{item.status}, 
             #{item.createBy}, #{item.createTime}, #{item.remark})
        </foreach>
    </insert>

</mapper>
