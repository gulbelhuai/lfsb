    <resultMap type="com.ruoyi.shebao.dto.ExpropriateeSubsidyFormDto" id="ExpropriateeSubsidyFormResult">
        <!-- 被征地参保补贴信息字段 -->
        <result property="id"                          column="id"                          />
        <result property="subsidyPersonId"             column="subsidy_person_id"           />
        <result property="landRequisitionBatch"        column="land_requisition_batch"      />
        <result property="villageStreet"               column="village_street"              />
        <result property="baseDate"                    column="base_date"                   />
        <result property="employeePensionMonths"       column="employee_pension_months"     />
        <result property="flexibleEmploymentMonths"    column="flexible_employment_months"  />
        <result property="difficultySubsidyYears"      column="difficulty_subsidy_years"    />
        <result property="ageAtBaseDate"               column="age_at_base_date"            />
        <result property="subsidyYears"                column="subsidy_years"               />
        <result property="subsidyAmount"               column="subsidy_amount"              />
        <result property="joinUrbanRuralInsurance"     column="join_urban_rural_insurance"  />
        <result property="joinEmployeePension"         column="join_employee_pension"       />
        <result property="hasEmployeePension"          column="has_employee_pension"        />
        <result property="status"                      column="es_status"                   />
        <result property="remark"                      column="es_remark"                   />
