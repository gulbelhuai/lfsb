<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.shebao.mapper.VillageOfficialMapper">
    
    <resultMap type="com.ruoyi.shebao.domain.VillageOfficial" id="VillageOfficialResult">
        <result property="id"                          column="id"                          />
        <result property="subsidyPersonId"             column="subsidy_person_id"           />
        <result property="totalServiceYears"           column="total_service_years"         />
        <result property="hasViolation"                column="has_violation"               />
        <result property="status"                      column="status"                      />
        <result property="delFlag"                     column="del_flag"                    />
        <result property="createBy"                    column="create_by"                   />
        <result property="createTime"                  column="create_time"                 />
        <result property="updateBy"                    column="update_by"                   />
        <result property="updateTime"                  column="update_time"                 />
        <result property="remark"                      column="remark"                      />
    </resultMap>

    <resultMap type="com.ruoyi.shebao.dto.VillageOfficialListResp" id="VillageOfficialListRespResult">
        <result property="id"                          column="id"                          />
        <result property="subsidyPersonId"             column="subsidy_person_id"           />
        <result property="name"                        column="name"                        />
        <result property="idCardNo"                    column="id_card_no"                  />
        <result property="gender"                      column="gender"                      />
        <result property="phone"                       column="phone"                       />
        <result property="villageName"                 column="village_name"                />
        <result property="totalServiceYears"           column="total_service_years"         />
        <result property="hasViolation"                column="has_violation"               />
        <result property="status"                      column="status"                      />
        <result property="approvalStatus"              column="approval_status"             />
        <result property="createTime"                  column="create_time"                 />
        <result property="updateTime"                  column="update_time"                 />
        <result property="remark"                      column="remark"                      />
    </resultMap>

    <resultMap type="com.ruoyi.shebao.dto.VillageOfficialFormDto" id="VillageOfficialFormResult">
        <!-- 村干部信息字段 -->
        <result property="id"                          column="id"                          />
        <result property="subsidyPersonId"             column="subsidy_person_id"           />
        <result property="totalServiceYears"           column="total_service_years"         />
        <result property="hasViolation"                column="has_violation"               />
        <result property="status"                      column="vo_status"                   />
        <result property="remark"                      column="vo_remark"                   />
        <!-- 基础信息字段 -->
        <result property="name"                        column="name"                        />
        <result property="gender"                      column="gender"                      />
        <result property="idCardNo"                    column="id_card_no"                  />
        <result property="birthday"                    column="birthday"                    />
        <result property="householdRegistration"       column="household_registration"      />
        <result property="homeAddress"                 column="home_address"                />
        <result property="phone"                       column="phone"                       />
        <result property="isAlive"                     column="is_alive"                    />
        <result property="deathDate"                   column="death_date"                 />
        <result property="isVillageCoopMember"         column="is_village_coop_member"      />
        <result property="streetOfficeId"              column="street_office_id"           />
        <result property="villageCommitteeId"          column="village_committee_id"        />
        <result property="userCode"                    column="user_code"                  />
    </resultMap>

    <sql id="selectVillageOfficialVo">
        select vo.id, vo.subsidy_person_id, vo.total_service_years, 
               vo.has_violation, vo.status, vo.del_flag, vo.create_by, vo.create_time, 
               vo.update_by, vo.update_time, vo.remark 
        from shebao_village_official vo
    </sql>

    <select id="selectVillageOfficialList" parameterType="com.ruoyi.shebao.dto.VillageOfficialListReq" resultMap="VillageOfficialListRespResult">
        select vo.id, vo.subsidy_person_id, vo.total_service_years, 
               vo.has_violation, vo.status, vo.create_time, vo.update_time, vo.remark,
               sp.name, sp.id_card_no, sp.gender, sp.phone, sp.approval_status,
               svc.village_name
        from shebao_village_official vo
        left join shebao_subsidy_person sp on vo.subsidy_person_id = sp.id
        left join shebao_village_committee svc on sp.village_committee_id = svc.id
        <where>
            vo.del_flag = '0'
            <if test="req.name != null and req.name != ''">
                AND sp.name like concat('%', #{req.name}, '%')
            </if>
            <if test="req.idCardNo != null and req.idCardNo != ''">
                AND sp.id_card_no like concat('%', #{req.idCardNo}, '%')
            </if>
            <if test="req.villageCode != null and req.villageCode != ''">
                AND svc.village_code = #{req.villageCode}
            </if>
            <if test="req.totalServiceYearsMin != null">
                AND vo.total_service_years >= #{req.totalServiceYearsMin}
            </if>
            <if test="req.totalServiceYearsMax != null">
                AND vo.total_service_years &lt;= #{req.totalServiceYearsMax}
            </if>
            <if test="req.hasViolation != null and req.hasViolation != ''">
                AND vo.has_violation = #{req.hasViolation}
            </if>
            <if test="req.status != null and req.status != ''">
                AND vo.status = #{req.status}
            </if>
        </where>
        order by vo.create_time desc
    </select>

    <select id="selectVillageOfficialFormById" parameterType="Long" resultMap="VillageOfficialFormResult">
        select vo.id, vo.subsidy_person_id, vo.total_service_years, 
               vo.has_violation, vo.status as vo_status, vo.remark as vo_remark,
               sp.name, sp.gender, sp.id_card_no, sp.birthday, sp.household_registration,
               sp.home_address,
               sp.phone, sp.is_alive, sp.death_date, sp.is_village_coop_member, 
               sp.street_office_id, sp.village_committee_id, sp.user_code
        from shebao_village_official vo
        left join shebao_subsidy_person sp on vo.subsidy_person_id = sp.id
        where vo.id = #{id} and vo.del_flag = '0'
    </select>

    <select id="selectBySubsidyPersonId" parameterType="Long" resultMap="VillageOfficialResult">
        <include refid="selectVillageOfficialVo"/>
        where subsidy_person_id = #{subsidyPersonId} and del_flag = '0'
        order by create_time desc
    </select>

    <insert id="batchInsertVillageOfficial" parameterType="java.util.List">
        insert into shebao_village_official
        (subsidy_person_id, total_service_years, has_violation, 
         status, create_by, create_time, remark)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.subsidyPersonId}, #{item.totalServiceYears}, #{item.hasViolation}, 
             #{item.status}, #{item.createBy}, #{item.createTime}, #{item.remark})
        </foreach>
    </insert>

</mapper>
